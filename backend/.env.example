# =============================================================================
# EventForge — Backend environment template
# Copy to .env or rely on repo-root .env when running locally.
# =============================================================================

# --- General ---
ENVIRONMENT=local
LOG_LEVEL=INFO

# --- Database (Postgres + pgvector) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=eventforge
POSTGRES_USER=eventforge
POSTGRES_PASSWORD=changeme

# --- AWS (local: LocalStack; prod: real AWS) ---
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
EVENT_BUS_NAME=eventforge-bus
SQS_QUEUE_PREFIX=eventforge
SQS_MAX_RECEIVE_COUNT=3

# --- Auth (Phase 3+) ---
AUTH_PROVIDER=clerk
CLERK_SECRET_KEY=

# --- LLM providers (Phase 3+) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TAVILY_API_KEY=
LLM_DEFAULT_MODEL=gpt-4o-mini
LLM_MAX_OUTPUT_TOKENS=4096

# --- Observability (Phase 4+) ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=eventforge-api
