# =============================================================================
# EventForge — Root environment template
# Copy to .env and fill in values. Service-specific overrides live in
# frontend/.env.example and backend/.env.example
# =============================================================================

# --- General ---
ENVIRONMENT=local
LOG_LEVEL=INFO

# --- Database (Postgres) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=eventforge
POSTGRES_USER=eventforge
POSTGRES_PASSWORD=changeme

# --- AWS (local: LocalStack; prod: real AWS) ---
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
EVENT_BUS_NAME=eventforge-bus
SQS_QUEUE_PREFIX=eventforge
SQS_MAX_RECEIVE_COUNT=3

# --- Auth ---
# Clerk or Auth0 — configure in Phase 3 (backend JWT) / Phase 4 (Clerk UI)
AUTH_PROVIDER=clerk
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# --- LLM providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TAVILY_API_KEY=
LLM_DEFAULT_MODEL=gpt-4o-mini

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=eventforge

# --- Frontend (passed through docker-compose) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
